# ===== Gemini (Google AI Studio) =====
# Required for summary, action-item, topic extraction and RAG answers.
# google-genai reads GOOGLE_API_KEY; we set both for convenience.
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_API_KEY=your_gemini_api_key_here

# ===== HuggingFace (pyannote diarization) =====
# Required for speaker diarization. Create a token at https://hf.co/settings/tokens
# and accept the model terms at https://hf.co/pyannote/speaker-diarization-3.1
# If left empty, the app still works but every segment is labelled "Speaker 1".
HF_TOKEN=your_hf_token_here

# ===== Models =====
GEMINI_MODEL=gemini-2.5-flash       # any current Gemini model id; swap here in one place
GEMINI_EMBED_MODEL=gemini-embedding-001
GEMINI_THINKING_LEVEL=high          # low | medium | high

# ===== Whisper =====
WHISPER_MODEL=base                  # tiny | base | small | medium | large-v3
WHISPER_DEVICE=cpu                  # cpu | cuda
WHISPER_COMPUTE_TYPE=int8           # int8 | float16 | float32

# ===== RAG =====
EMBED_DIM=768                       # 768 | 1536 | 3072
RAG_TOP_K=8

# ===== Auth (optional) =====
# Leave AUTH_PASSWORD empty to keep the API open (default). Set it to require login:
# POST /api/auth/login {username, password} -> {access_token}; send it as
# "Authorization: Bearer <token>" on all /api/* calls except /api/health and /api/auth/login.
AUTH_USERNAME=admin
AUTH_PASSWORD=                       # set a strong password to turn auth ON
AUTH_SECRET=                         # HMAC signing key; defaults to AUTH_PASSWORD if empty
AUTH_TOKEN_TTL_MINUTES=1440          # token lifetime (minutes); 1440 = 24h

# ===== Paths / server =====
DATA_DIR=../data
CORS_ORIGINS=http://localhost:5173
